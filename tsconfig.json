{
    "compilerOptions": {
        "target": "ES2017",
        "module": "es2015",
        "moduleResolution": "node",
        "lib": [
            "dom",
            "es2017"
        ],
        "outDir": "dist",
        "strict": false,
        "removeComments": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": [
        "./**/*.ts"
    ]
}